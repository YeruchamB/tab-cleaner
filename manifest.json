{
  "manifest_version": 3,
  "name": "Tab Cleaner",
  "version": "1.0.0",
  "description": "Instantly close all open Zoom tabs with one click.",
  "permissions": ["tabs"],
  "host_permissions": [
    "*://*.zoom.us/*",
    "*://*.zoom.com/*",
    "*://*.zoomgov.com/*",
    "*://federation.intuit.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
